<view class="fee-page data-v-5c9f0dfe"><view class="card summary-card data-v-5c9f0dfe"><text class="sum-title data-v-5c9f0dfe">缴费概览</text><view class="sum-row data-v-5c9f0dfe"><view class="sum-item data-v-5c9f0dfe"><text class="sum-num blue data-v-5c9f0dfe">{{unpaidCount}}</text><text class="sum-label data-v-5c9f0dfe">待缴费</text></view><view class="sum-item data-v-5c9f0dfe"><text class="sum-num green data-v-5c9f0dfe">{{paidCount}}</text><text class="sum-label data-v-5c9f0dfe">已缴清</text></view><view class="sum-item data-v-5c9f0dfe"><text class="sum-num red data-v-5c9f0dfe">{{overdueCount}}</text><text class="sum-label data-v-5c9f0dfe">已逾期</text></view></view></view><block wx:for="{{$root.l0}}" wx:for-item="bill" wx:for-index="__i0__" wx:key="id"><view class="card data-v-5c9f0dfe"><view class="bill-header data-v-5c9f0dfe"><text class="bill-no data-v-5c9f0dfe">{{bill.$orig.billNo}}</text><text class="{{bill.m0}}">{{''+bill.m1+''}}</text></view><view class="bill-body data-v-5c9f0dfe"><view class="bill-row data-v-5c9f0dfe"><text class="bill-key data-v-5c9f0dfe">费用项目</text><text class="bill-val data-v-5c9f0dfe">{{bill.$orig.feeItemId}}</text></view><view class="bill-row data-v-5c9f0dfe"><text class="bill-key data-v-5c9f0dfe">金额</text><text class="bill-val price data-v-5c9f0dfe">{{"¥"+bill.$orig.amount}}</text></view><view class="bill-row data-v-5c9f0dfe"><text class="bill-key data-v-5c9f0dfe">已付</text><text class="bill-val data-v-5c9f0dfe">{{"¥"+bill.$orig.paidAmount}}</text></view><view class="bill-row data-v-5c9f0dfe"><text class="bill-key data-v-5c9f0dfe">周期</text><text class="bill-val data-v-5c9f0dfe">{{bill.$orig.billPeriodStart+" ~ "+bill.$orig.billPeriodEnd}}</text></view><view class="bill-row data-v-5c9f0dfe"><text class="bill-key data-v-5c9f0dfe">截止日</text><text class="{{['bill-val','data-v-5c9f0dfe',(bill.$orig.status===3)?'red':'']}}">{{bill.$orig.dueDate}}</text></view></view><block wx:if="{{bill.$orig.status===0||bill.$orig.status===3}}"><button data-event-opts="{{[['tap',[['handlePay',['$0'],[[['bills','id',bill.$orig.id]]]]]]]}}" class="pay-btn data-v-5c9f0dfe" bindtap="__e">立即缴费</button></block></view></block><block wx:if="{{$root.g0===0}}"><view class="empty data-v-5c9f0dfe">暂无账单</view></block></view>