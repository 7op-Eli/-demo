<view class="visitor-audit data-v-5a67c654"><block wx:for="{{visitors}}" wx:for-item="v" wx:for-index="__i0__" wx:key="id"><view class="card data-v-5a67c654"><view class="visitor-header data-v-5a67c654"><text class="visitor-name data-v-5a67c654">{{v.visitorName}}</text><block wx:if="{{v.status===0}}"><text class="visitor-status tag tag-orange data-v-5a67c654">待审核</text></block></view><view class="info-row data-v-5a67c654"><text class="key data-v-5a67c654">电话</text><text class="val data-v-5a67c654">{{v.visitorPhone}}</text></view><block wx:if="{{v.vehiclePlate}}"><view class="info-row data-v-5a67c654"><text class="key data-v-5a67c654">车辆</text><text class="val data-v-5a67c654">{{v.vehiclePlate}}</text></view></block><view class="info-row data-v-5a67c654"><text class="key data-v-5a67c654">事由</text><text class="val data-v-5a67c654">{{v.visitPurpose}}</text></view><view class="info-row data-v-5a67c654"><text class="key data-v-5a67c654">人数</text><text class="val data-v-5a67c654">{{v.visitCount+" 人"}}</text></view><block wx:if="{{v.status===0}}"><view class="audit-actions data-v-5a67c654"><button data-event-opts="{{[['tap',[['approve',['$0'],[[['visitors','id',v.id,'id']]]]]]]}}" class="approve-btn data-v-5a67c654" bindtap="__e">通过</button><view class="reject-area data-v-5a67c654"><input class="reject-input data-v-5a67c654" placeholder="拒绝原因" data-event-opts="{{[['input',[['__set_model',['','rejectRemark','$event',[]]]]]]}}" value="{{rejectRemark}}" bindinput="__e"/><button data-event-opts="{{[['tap',[['reject',['$0'],[[['visitors','id',v.id,'id']]]]]]]}}" class="reject-btn data-v-5a67c654" bindtap="__e">拒绝</button></view></view></block><block wx:else><view class="audit-result data-v-5a67c654"><text class="result-text data-v-5a67c654">{{"已"+(v.status===1?'通过':v.status===4?'拒绝':'处理')}}</text></view></block></view></block><block wx:if="{{$root.g0===0}}"><view class="empty data-v-5a67c654">暂无需审核的访客</view></block></view>