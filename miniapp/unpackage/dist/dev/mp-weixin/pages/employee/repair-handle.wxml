<view class="repair-handle data-v-b6507200"><block wx:if="{{order}}"><view class="card data-v-b6507200"><view class="detail-header data-v-b6507200"><text class="order-title data-v-b6507200">{{order.orderNo}}</text><text class="{{$root.m0}}">{{$root.m1}}</text></view><view class="info-row data-v-b6507200"><text class="key data-v-b6507200">业主</text><text class="val data-v-b6507200">{{order.contactName}}</text></view><view class="info-row data-v-b6507200"><text class="key data-v-b6507200">电话</text><text class="val data-v-b6507200">{{order.contactPhone}}</text></view><view class="info-row data-v-b6507200"><text class="key data-v-b6507200">类型</text><text class="val data-v-b6507200">{{order.repairType}}</text></view><view class="info-row data-v-b6507200"><text class="key data-v-b6507200">描述</text><text class="val data-v-b6507200">{{order.description}}</text></view><view class="action-btns data-v-b6507200"><block wx:if="{{order.status===1}}"><button data-event-opts="{{[['tap',[['csAcceptOrder',['$event']]]]]}}" class="action-btn data-v-b6507200" bindtap="__e">客服接单</button></block><block wx:if="{{order.status===2}}"><view class="data-v-b6507200"><input class="input data-v-b6507200" type="number" placeholder="维修人员ID" data-event-opts="{{[['input',[['__set_model',['','assigneeId','$event',[]]]]]]}}" value="{{assigneeId}}" bindinput="__e"/><button data-event-opts="{{[['tap',[['dispatchOrder',['$event']]]]]}}" class="action-btn data-v-b6507200" bindtap="__e">派单</button></view></block><block wx:if="{{order.status===3}}"><button data-event-opts="{{[['tap',[['acceptRepairOrder',['$event']]]]]}}" class="action-btn data-v-b6507200" bindtap="__e">维修接单</button></block><block wx:if="{{order.status===4}}"><view class="data-v-b6507200"><textarea class="input textarea data-v-b6507200" placeholder="填写进度说明" data-event-opts="{{[['input',[['__set_model',['','progressContent','$event',[]]]]]]}}" value="{{progressContent}}" bindinput="__e"></textarea><button data-event-opts="{{[['tap',[['reportProgressOrder',['$event']]]]]}}" class="action-btn green data-v-b6507200" bindtap="__e">上报进度</button><button data-event-opts="{{[['tap',[['completeRepairOrder',['$event']]]]]}}" class="action-btn data-v-b6507200" bindtap="__e">维修完成</button></view></block><block wx:if="{{order.status===5}}"><view class="data-v-b6507200"><input class="input data-v-b6507200" placeholder="回访记录" data-event-opts="{{[['input',[['__set_model',['','followUpNote','$event',[]]]]]]}}" value="{{followUpNote}}" bindinput="__e"/><button data-event-opts="{{[['tap',[['followUpOrder',['$event']]]]]}}" class="action-btn green data-v-b6507200" bindtap="__e">提交回访</button></view></block></view></view></block><view class="card data-v-b6507200"><view class="section-title data-v-b6507200">操作日志</view><block wx:for="{{logs}}" wx:for-item="log" wx:for-index="__i0__" wx:key="id"><view class="log-item data-v-b6507200"><view class="log-dot data-v-b6507200"></view><view class="log-body data-v-b6507200"><text class="log-action data-v-b6507200">{{log.action}}</text><text class="log-content data-v-b6507200">{{log.content}}</text><text class="log-time data-v-b6507200">{{log.createdAt}}</text></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty data-v-b6507200">暂无日志</view></block></view></view>